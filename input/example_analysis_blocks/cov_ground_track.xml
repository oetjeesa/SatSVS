<Analysis>
    <Type>cov_ground_track</Type>
    <ConstellationID>1</ConstellationID>
    <SatelliteID>1</SatelliteID>            <!-- Optional: omit to plot all satellites of the constellation -->
    <Plot3D>False</Plot3D>                  <!-- Optional: 3D globe render (needs pyvista) -->
    <EarthClouds>False</EarthClouds>        <!-- Optional: cloud layer on the 3D globe -->
    <SatelliteModelFile>../input/my_satellite.glb</SatelliteModelFile>  <!-- Optional: STL (monochrome) or Blender .glb/.gltf (coloured) model -->
    <ModelRamAxis>+x</ModelRamAxis>         <!-- Optional: model axis along the flight direction -->
    <ModelNadirAxis>+z</ModelNadirAxis>     <!-- Optional: model axis towards nadir -->
    <StationCones>False</StationCones>      <!-- Optional: ground-station visibility cones on the 3D globe -->
    <SatelliteCone>False</SatelliteCone>    <!-- Optional: satellite-to-horizon cone on the 3D globe -->
    <MP4>False</MP4>                        <!-- Optional: 2D + 3D world-map movies (needs imageio + imageio-ffmpeg) -->
</Analysis>
