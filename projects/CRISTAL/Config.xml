<?xml version="1.0" encoding="utf-8"?>
<!--Mission: Copernicus expansion CRISTAL (polar ice and snow topography
    altimeter, high-inclination non-SSO orbit for polar coverage).
    Nadir instrument: repeat ground track.
    Representative public orbit and instrument values; reduce the user grid or
    the simulation window for quick looks.-->
<!--Copernicus Expansion mission analysis run: cov_ground_track, cov_satellite_contour,
    cov_pass_time, obs_swath_conical, sat_battery_depth_discharge,
    sat_eclipse_duration, sat_data_storage, sat_data_latency, orb_deltav_element.
    HPOP propagation so the station-keeping delta-v analysis shows real drift.
    Data/power values are representative; assumptions:
      - IRIS is a nadir altimeter: modelled as a 15 km conical footprint, no revisit map (grid too coarse)
      - SSR 600 Gbit, 30 Mbps effective SARIn rate and X-band 520 Mbps are assumptions
      - Polar station set (Svalbard, Inuvik, Troll) assumed for the polar ice mission
      - Station-keeping deadband 500 m on the mean altitude: sits above the ~0.1 km
        mean-element estimation noise; near-zero burns over a days-long window is
        the physically expected result at this altitude
      - Ground stations: Svalbard, Inuvik, Troll (5 deg mask)
      - 15 min ground processing added to the data latency-->
<Scenario>
  <SpaceSegment>
    <Constellation>
      <ConstellationID>1</ConstellationID>
      <NumOfSatellites>1</NumOfSatellites>
      <NumOfPlanes>1</NumOfPlanes>
      <ConstellationName>CRISTAL</ConstellationName>
      <ReceiverConstellation>1</ReceiverConstellation>
      <ObsSwathStop>7500.0</ObsSwathStop>
      <ObsSwathStop>7500.0</ObsSwathStop>
      <ObsSwathStop>7500.0</ObsSwathStop>
      <Satellite>
        <SatelliteID>1</SatelliteID>
        <Plane>1</Plane>
        <EpochMJD>61072.0</EpochMJD>
        <SemiMajorAxis>7138137</SemiMajorAxis>
        <Eccentricity>0.0011</Eccentricity>
        <Inclination>88.0</Inclination>
        <RAAN>0.0</RAAN>
        <ArgOfPerigee>0.0</ArgOfPerigee>
        <MeanAnomaly>0.0</MeanAnomaly>
      </Satellite>
    </Constellation>
  </SpaceSegment>
  <GroundSegment>
    <Network>
      <NumStation>3</NumStation>
      <NetworkName>Downlink</NetworkName>
      <GroundStation>
        <Type>Downlink</Type>
        <ConstellationID>1</ConstellationID>
        <GroundStationID>1</GroundStationID>
        <GroundStationName>Svalbard</GroundStationName>
        <Latitude>78.229</Latitude>
        <Longitude>15.408</Longitude>
        <Height>450</Height>
        <ReceiverConstellation>1</ReceiverConstellation>
        <ElevationMask>5</ElevationMask>
      </GroundStation>
      <GroundStation>
        <Type>Downlink</Type>
        <ConstellationID>1</ConstellationID>
        <GroundStationID>2</GroundStationID>
        <GroundStationName>Inuvik</GroundStationName>
        <Latitude>68.319</Latitude>
        <Longitude>-133.549</Longitude>
        <Height>90</Height>
        <ReceiverConstellation>1</ReceiverConstellation>
        <ElevationMask>5</ElevationMask>
      </GroundStation>
      <GroundStation>
        <Type>Downlink</Type>
        <ConstellationID>1</ConstellationID>
        <GroundStationID>3</GroundStationID>
        <GroundStationName>Troll</GroundStationName>
        <Latitude>-72.012</Latitude>
        <Longitude>2.535</Longitude>
        <Height>1270</Height>
        <ReceiverConstellation>1</ReceiverConstellation>
        <ElevationMask>5</ElevationMask>
      </GroundStation>
    </Network>
  </GroundSegment>
  <UserSegment>
    <User>
      <Type>Grid</Type>
      <LatMin>-85</LatMin>
      <LatMax>85</LatMax>
      <LonMin>-180</LonMin>
      <LonMax>180</LonMax>
      <LatStep>5</LatStep>
      <LonStep>5</LonStep>
      <Height>0</Height>
      <ReceiverConstellation>1</ReceiverConstellation>
      <ElevationMask>5</ElevationMask>
    </User>
  </UserSegment>
  <SimulationManager>
    <StartDate>2026-02-01 00:00:00</StartDate>
    <StopDate>2026-02-05 00:00:00</StopDate>
    <TimeStep>60</TimeStep>
    <IncludeStation2SpaceLinks>True</IncludeStation2SpaceLinks>
    <IncludeUser2SpaceLinks>True</IncludeUser2SpaceLinks>
    <IncludeSpace2SpaceLinks>False</IncludeSpace2SpaceLinks>
    <OrbitsFromPreviousRun>False</OrbitsFromPreviousRun>
    <OrbitPropagator>HPOP</OrbitPropagator>
    <HPOP>
      <IntegratorMinStep>0.001</IntegratorMinStep>
      <IntegratorMaxStep>300</IntegratorMaxStep>
      <IntegratorPositionTolerance>1.0</IntegratorPositionTolerance>
      <Mass>1700</Mass>
