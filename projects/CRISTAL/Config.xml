    </Analysis>
    <Analysis>
      <Type>obs_swath_conical</Type>
      <Revisit>False</Revisit>
      <Statistic>Mean</Statistic>
    </Analysis>
    <Analysis>
      <Type>sat_battery_depth_discharge</Type>
      <BatteryCapacityWh>2500</BatteryCapacityWh>
      <InitialSoC>1.0</InitialSoC>
      <SolarPanelArea>8.0</SolarPanelArea>
      <PanelEfficiency>0.28</PanelEfficiency>
      <BasePowerDrawW>900</BasePowerDrawW>
      <InstrumentPowerDrawW>400</InstrumentPowerDrawW>
      <PayloadLatitudeLimit>90</PayloadLatitudeLimit>
    </Analysis>
    <Analysis>
      <Type>sat_eclipse_duration</Type>
    </Analysis>
    <Analysis>
      <Type>sat_data_storage</Type>
      <SSRCapacityGbits>600</SSRCapacityGbits>
      <InitialFillGbits>0</InitialFillGbits>
      <InstrumentRateMbps>30</InstrumentRateMbps>
      <DownlinkRateMbps>520</DownlinkRateMbps>
      <PayloadLatitudeLimit>90</PayloadLatitudeLimit>
    </Analysis>
    <Analysis>
      <Type>sat_data_latency</Type>
      <SSRCapacityGbits>600</SSRCapacityGbits>
      <InitialFillGbits>0</InitialFillGbits>
      <InstrumentRateMbps>30</InstrumentRateMbps>
      <DownlinkRateMbps>520</DownlinkRateMbps>
      <PayloadLatitudeLimit>90</PayloadLatitudeLimit>
      <GroundProcessingMin>15</GroundProcessingMin>
    </Analysis>
    <Analysis>
      <Type>orb_deltav_element</Type>
      <TargetType>Altitude</TargetType>
      <DeadBand>500</DeadBand>
      <ConstellationID>1</ConstellationID>
      <SatelliteID>1</SatelliteID>
    </Analysis>
  </SimulationManager>
</Scenario>
